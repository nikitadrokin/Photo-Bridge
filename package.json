{
  "name": "tauri-template",
  "version": "0.1.0",
  "description": "Reusable Tauri app template",
  "type": "module",
  "workspaces": [
    "src-ui"
  ],
  "scripts": {
    "dev:ui": "cd src-ui && bun run dev",
    "build:ui": "cd src-ui && bun run build",
    "dev:tauri": "APPLE_SIGNING_IDENTITY=- tauri dev",
    "build:tauri": "tauri build",
    "typecheck": "cd src-ui && tsc --noEmit"
  },
  "keywords": ["tauri", "react", "template"],
  "author": "dna",
  "license": "MIT",
  "devDependencies": {
    "@tauri-apps/cli": "^2.9.6",
    "@types/bun": "^1.3.11",
    "@types/node": "^22.14.0",
    "typescript": "^5.9.3"
  }
}
