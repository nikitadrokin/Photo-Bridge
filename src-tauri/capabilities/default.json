{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "dialog:default",
    "core:window:allow-start-dragging",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "bun",
          "cmd": "bun",
          "args": true
        },
        {
          "name": "node",
          "cmd": "node",
          "args": true
        },
        {
          "name": "binaries/pb",
          "sidecar": true,
          "args": true
        },
        {
          "name": "exec-sh",
          "cmd": "sh",
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "bun",
          "cmd": "bun",
          "args": true
        },
        {
          "name": "node",
          "cmd": "node",
          "args": true
        },
        {
          "name": "binaries/pb",
          "sidecar": true,
          "args": true
        },
        {
          "name": "exec-sh",
          "cmd": "sh",
          "args": true
        }
      ]
    }
  ]
}
