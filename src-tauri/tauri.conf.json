{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PhotoBridge",
  "mainBinaryName": "photo-bridge",
  "version": "0.0.11",
  "identifier": "me.nkdr.photo-bridge",
  "build": {
    "frontendDist": "../src-ui/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun run build:sidecar && cd src-ui && bun run dev",
    "beforeBuildCommand": "bun run build:sidecar && cd src-ui && bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "PhotoBridge",
        "width": 800,
        "height": 600,
        "minWidth": 420,
        "minHeight": 360,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 22,
          "y": 30
        },
        "hiddenTitle": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/itp"]
  }
}
