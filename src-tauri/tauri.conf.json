{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Tauri Template",
  "mainBinaryName": "tauri-template",
  "version": "0.1.0",
  "identifier": "com.example.tauri-template",
  "build": {
    "frontendDist": "../src-ui/dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "cd src-ui && bun run dev",
    "beforeBuildCommand": "cd src-ui && bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "Tauri Template",
        "width": 800,
        "height": 600,
        "minWidth": 420,
        "minHeight": 360,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 26
        },
        "hiddenTitle": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
